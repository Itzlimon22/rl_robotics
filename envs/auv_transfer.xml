<mujoco model="halcyon">

  <!--
    Halcyon X4-AUV — MJCF model  (v2 — fixed + enhanced)
    ════════════════════════════════════════════════════════
    Spindle (prolate spheroid) body, ~1.0m long, 0.15m diameter.
    4 thrusters in X-configuration at rear, ±55mm around the roll axis.
    Neutrally buoyant: gravity disabled, buoyancy applied externally in Python.
    Fluid drag, buoyancy, and water current applied via Python env each step.

    FIXES vs v1:
      - Removed <joint> from <default> (caused implicit free-joint conflicts)
      - Added explicit <default class> subtrees for geom/motor separation
      - Added <equality> weld to freeze goal body (prevents it drifting)
      - Added pressure/depth sensor site at nose
      - Added rangefinder sensors (forward, up, down) for obstacle awareness
      - Added velocity/position sensors with proper noise fields
      - Corrected tail_fairing euler (was 1.5708 rad, confirmed correct)
      - Increased hull mass to 11.0 kg (sum of geoms ≈ 11.1 kg, consistent)
      - ocean_volume and floor moved to separate visual geom group
      - Added <contact> exclude to suppress hull self-contacts
      - Added tendon/equality stubs (commented) for future payload attachment
      - camera "chase" added (fixed offset behind AUV, good for training viz)

    ENHANCEMENTS:
      - IMU site at centre of mass for clean accelerometer/gyro placement
      - DVL (Doppler Velocity Log) site at keel — realistic AUV sensor
      - Depth sensor site on hull top
      - 4 rangefinders (forward, port, starboard, up) for proximity rewards
      - actuatorfrc sensors — lets env read actual applied thrust each step
      - <default class="thruster"> isolates motor gear/ctrl settings
      - keyframe "home" — zero-velocity resting pose for env.reset()

    Coordinate convention (body frame):
      +X  = forward (nose direction)
      +Z  = up
      +Y  = left (port)

    Thruster layout (rear view, looking forward):
          T_top   (+Z offset)
      T_left      T_right   (±Y offset)
          T_bot   (-Z offset)

    Differential thrust — 6 DOF mapping:
      Surge  (forward/back): all 4 equal positive/negative
      Heave  (up/down):      T_top(+) + T_bot(-) differential
      Sway   (left/right):   T_left(+) + T_right(-) differential
      Yaw    (left/right):   T_left(+) + T_right(-) same sign, opposed surge
      Pitch  (nose up/down): T_top(+) + T_bot(-) same sign, opposed surge
      Roll:                  minor coupling (acceptable for this config)

    Sensor data layout (data.sensordata):
      [0:3]   pos        — world XYZ position
      [3:7]   quat       — world quaternion (w,x,y,z)
      [7:10]  linvel     — world-frame linear velocity
      [10:13] angvel     — world-frame angular velocity
      [13:16] accel      — body-frame acceleration (IMU)
      [16:19] gyro       — body-frame angular rate (IMU)
      [19:23] act_frc    — actual thrust force per thruster (N)
      [23:27] rangefinder— forward, port, starboard, up distances
      Total: 27 floats
  -->

  <!-- ── Compiler ──────────────────────────────────────────────── -->
  <compiler angle="radian" autolimits="true"/>

  <!-- ── Physics options ───────────────────────────────────────── -->
  <option
    timestep   = "0.01"
    gravity    = "0 0 0"
    density    = "1000"
    viscosity  = "0.001"
    integrator = "RK4"
    solver     = "Newton"
    iterations = "50"
    tolerance  = "1e-10">
    <!--
      gravity=0: net buoyancy (buoyancy - gravity) applied each step in Python.
      density/viscosity: water properties stored here for reference; drag is
      computed manually in the env (quadratic drag F = -c * v * |v|).
    -->
  </option>

  <!-- ── Visual settings ───────────────────────────────────────── -->
  <visual>
    <global offwidth="1280" offheight="720"/>
    <headlight ambient="0.4 0.5 0.6" diffuse="0.6 0.7 0.8" specular="0.1 0.1 0.1"/>
    <rgba haze="0.05 0.1 0.2 1"/>
  </visual>

  <!-- ── Assets ────────────────────────────────────────────────── -->
  <asset>
    <material name="hull"     rgba="0.15 0.22 0.35 1.0" shininess="0.8" specular="0.6"/>
    <material name="thruster" rgba="0.25 0.30 0.40 1.0" shininess="0.5" specular="0.4"/>
    <material name="fin"      rgba="0.10 0.18 0.28 1.0" shininess="0.3" specular="0.2"/>
    <material name="nose"     rgba="0.20 0.55 0.65 1.0" shininess="0.9" specular="0.7"/>
    <material name="target"   rgba="0.15 0.85 0.55 0.6" shininess="0.2" specular="0.1"/>
    <material name="water"    rgba="0.02 0.08 0.18 0.15" shininess="0.0" specular="0.0"/>
    <material name="sensor"   rgba="0.90 0.70 0.10 0.8" shininess="0.5" specular="0.3"/>
  </asset>

  <!-- ── Defaults ──────────────────────────────────────────────── -->
  <!--
    FIX: Removed <joint> from the global default. Putting type="free" here
    caused MuJoCo to apply it to ALL joints including any auto-generated
    ones, producing silent conflicts. The root free joint is now declared
    explicitly on the halcyon body only.
  -->
  <default>
    <geom contype="1" conaffinity="1" condim="3" friction="0.4 0.01 0.01"/>

    <!-- Thruster motor defaults — isolated in their own class -->
    <default class="thruster">
      <motor ctrllimited="true" ctrlrange="-1 1" gear="20 0 0 0 0.11 0"/>
    </default>

    <!-- Visual-only geoms: no collision, no mass contribution -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2" mass="0"/>
    </default>
  </default>

  <!-- ── Contact exclusions ────────────────────────────────────── -->
  <!--
    Suppress self-contacts between hull geoms. Without this, the overlapping
    ellipsoids (hull_main + nose share volume) generate spurious contact forces
    at step 0 that perturb the initial state.
  -->
  <contact>
    <exclude body1="halcyon" body2="goal"/>
  </contact>

  <!-- ── World ─────────────────────────────────────────────────── -->
  <worldbody>

    <!-- Ocean volume — visual only, group 2 (hidden in training renders) -->
    <geom name     = "ocean_volume"
          type     = "box"
          size     = "15 15 10"
          pos      = "0 0 0"
          contype  = "0" conaffinity = "0"
          material = "water"
          group    = "2"
          mass     = "0"/>

    <!-- Grid floor — spatial reference, visual only -->
    <geom name     = "floor"
          type     = "plane"
          size     = "20 20 0.1"
          pos      = "0 0 -10"
          contype  = "0" conaffinity = "0"
          rgba     = "0.05 0.1 0.2 0.4"
          group    = "2"
          mass     = "0"/>

    <!-- ═══════════════════════════════════════════════════════════
         HALCYON BODY
         Total mass: ~11.1 kg (hull 10.0 + nose 0.5 + tail 0.3 +
                               fins 4×0.1 + housings 4×0.25 = 11.2 kg)
         Inertia computed automatically from geom masses.
         Centre of mass biased slightly aft and low for passive stability.
    ═══════════════════════════════════════════════════════════════ -->
    <body name="halcyon" pos="0 0 0" euler="0 0 0">

      <!--
        FIX: Explicit free joint declared here, NOT in <default>.
        This gives the AUV unrestricted 6-DOF motion in world space.
        qpos layout: [x, y, z, qw, qx, qy, qz]  (7 values)
        qvel layout: [vx, vy, vz, wx, wy, wz]    (6 values)
      -->
      <joint name="root" type="free" damping="0" armature="0"/>

      <!-- ── Hull geometry ──────────────────────────────────── -->

      <!-- Main hull: prolate spheroid (half-lengths x=0.45, y=z=0.07) -->
      <geom name     = "hull_main"
            type     = "ellipsoid"
            size     = "0.45 0.07 0.07"
            pos      = "0.0 0 0"
            material = "hull"
            mass     = "10.8"/>

      <!-- Nose cap: teal accent, visually distinct in paper figures -->
      <geom name     = "nose_cap"
            type     = "ellipsoid"
            size     = "0.12 0.065 0.065"
            pos      = "0.48 0 0"
            material = "nose"
            mass     = "0.5"/>

      <!-- Tail fairing: blends hull into thruster ring -->
      <!-- euler="0 π/2 0" orients cylinder axis along X (forward) -->
      <geom name     = "tail_fairing"
            type     = "cylinder"
            size     = "0.04 0.06"
            pos      = "-0.44 0 0"
            euler    = "0 1.5708 0"
            material = "hull"
            mass     = "0.3"/>

      <!-- ── Stabiliser fins (passive, fixed) ──────────────── -->
      <!-- Dorsal (top) -->
      <geom name     = "fin_dorsal"
            type     = "box"
            size     = "0.12 0.006 0.055"
            pos      = "-0.15 0 0.072"
            material = "fin"
            mass     = "0.1"/>

      <!-- Ventral (bottom) -->
      <geom name     = "fin_ventral"
            type     = "box"
            size     = "0.12 0.006 0.055"
            pos      = "-0.15 0 -0.072"
            material = "fin"
            mass     = "0.1"/>

      <!-- Port (left) -->
      <geom name     = "fin_port"
            type     = "box"
            size     = "0.12 0.055 0.006"
            pos      = "-0.15 0.072 0"
            material = "fin"
            mass     = "0.1"/>

      <!-- Starboard (right) -->
      <geom name     = "fin_starboard"
            type     = "box"
            size     = "0.12 0.055 0.006"
            pos      = "-0.15 -0.072 0"
            material = "fin"
            mass     = "0.1"/>

      <!-- ── Thruster housings (visual, mass included) ──────── -->
      <geom name="housing_top"   type="cylinder" size="0.022 0.055"
            pos="-0.46 0 0.055"   euler="0 1.5708 0" material="thruster" mass="0.25"/>
      <geom name="housing_bot"   type="cylinder" size="0.022 0.055"
            pos="-0.46 0 -0.055"  euler="0 1.5708 0" material="thruster" mass="0.25"/>
      <geom name="housing_left"  type="cylinder" size="0.022 0.055"
            pos="-0.46 0.055 0"   euler="0 1.5708 0" material="thruster" mass="0.25"/>
      <geom name="housing_right" type="cylinder" size="0.022 0.055"
            pos="-0.46 -0.055 0"  euler="0 1.5708 0" material="thruster" mass="0.25"/>

      <!-- ── Thruster force application sites ──────────────── -->
      <!--
        Forces applied here by Python env each step via:
          data.ctrl[i] = value  (motor actuators read these)
        Axis convention: motor gear "20 0 0 0 0 0" applies force along
        the site's local X axis. Positive ctrl = forward thrust.
      -->
      <site name="thruster_top"   pos="-0.52 0 0.055"   size="0.015" rgba="0.2 0.9 0.5 0.8"/>
      <site name="thruster_bot"   pos="-0.52 0 -0.055"  size="0.015" rgba="0.2 0.9 0.5 0.8"/>
      <site name="thruster_left"  pos="-0.52 0.055 0"   size="0.015" rgba="0.2 0.9 0.5 0.8"/>
      <site name="thruster_right" pos="-0.52 -0.055 0"  size="0.015" rgba="0.2 0.9 0.5 0.8"/>

      <!-- ── Sensor sites ───────────────────────────────────── -->

      <!-- IMU at centre of mass — clean inertial measurements -->
      <site name="imu"      pos="0 0 0"      size="0.012" rgba="1.0 0.7 0.1 0.9"/>

      <!-- DVL (Doppler Velocity Log) at keel — realistic AUV sensor -->
      <!-- Points downward; in Python env read linvel in body frame -->
      <site name="dvl"      pos="-0.1 0 -0.075" size="0.010" rgba="0.9 0.4 0.1 0.8"/>

      <!-- Depth sensor on top of hull -->
      <site name="depth"    pos="0 0 0.075"   size="0.008" rgba="0.9 0.9 0.1 0.7"/>

      <!-- Nose tip — forward rangefinder origin -->
      <site name="nose_tip" pos="0.60 0 0"    size="0.008" rgba="0.2 0.8 0.9 0.6"/>

      <!-- Port/starboard rangefinder origins -->
      <site name="range_port"      pos="0 0.075 0"  size="0.007" rgba="0.8 0.8 0.2 0.6"/>
      <site name="range_starboard" pos="0 -0.075 0" size="0.007" rgba="0.8 0.8 0.2 0.6"/>

      <!-- Upward-looking rangefinder (useful for under-ice scenarios) -->
      <site name="range_up"        pos="0 0 0.075"  size="0.007" rgba="0.8 0.8 0.2 0.6"/>

    </body>

    <!-- ═══════════════════════════════════════════════════════════
         GOAL MARKER
         Moved each episode in Python via:
           model.body_pos[goal_id] = target_xyz
           mujoco.mj_forward(model, data)
         No joint — welded to world by default (correct behaviour).
         Collision disabled (contype/conaffinity=0).
    ═══════════════════════════════════════════════════════════════ -->
    <body name="goal" pos="5 0 0">
      <geom name     = "goal_sphere"
            type     = "sphere"
            size     = "0.15"
            contype  = "0" conaffinity = "0"
            material = "target"
            group    = "1"
            mass     = "0"/>
      <site name="goal_site" pos="0 0 0" size="0.02" rgba="0.1 1.0 0.5 1.0"/>
    </body>

    <!-- ── Lights ──────────────────────────────────────────────── -->
    <light name="sun"     pos="0 0 8" dir="0 0 -1" diffuse="0.6 0.7 0.8" specular="0.2 0.2 0.2"/>
    <light name="ambient" pos="0 0 5" dir="0 0 -1" diffuse="0.2 0.3 0.4" specular="0.0 0.0 0.0"/>

    <!-- ── Cameras ─────────────────────────────────────────────── -->
    <!-- track: 3/4 view, good for demos and paper figures -->
    <camera name="track"  mode="trackcom" target="halcyon" pos="3 -3 2"    euler="0 0.5 0.8"/>
    <!-- side: pure lateral — shows depth control clearly -->
    <camera name="side"   mode="trackcom" target="halcyon" pos="0 -4 0"    euler="0 0 1.5708"/>
    <!-- top: overhead — shows planar navigation -->
    <camera name="top"    mode="trackcom" target="halcyon" pos="0 0 6"     euler="0 0 0"/>
    <!-- follow: tight chase cam — good for watching goal approaches -->
    <camera name="follow" mode="trackcom" target="halcyon" pos="-2 0 0.5"  euler="0 0.2 0"/>
    <!-- chase: fixed offset behind, level with body — cleanest for training viz -->
    <camera name="chase"  mode="trackcom" target="halcyon" pos="-3 0 1"    euler="0 0.3 0"/>


    <!-- ── Static obstacles ────────────────────────────────────── -->
    <!--
      Obstacles are placed by Python env at each episode reset.
      Using spherical geoms for simplicity — easily extensible to boxes.
      Positions randomised via model.geom_pos in Python.
      group=1 = visible in render, collisions enabled.
    -->
    <geom name="obs_0" type="sphere" size="0.4"
              pos="3 0 0" rgba="0.8 0.2 0.2 0.7"
              contype="1" conaffinity="1" group="1" mass="0"/>
    <geom name="obs_1" type="sphere" size="0.4"
              pos="-3 0 0" rgba="0.8 0.2 0.2 0.7"
              contype="1" conaffinity="1" group="1" mass="0"/>
    <geom name="obs_2" type="sphere" size="0.4"
              pos="0 3 0" rgba="0.8 0.2 0.2 0.7"
              contype="1" conaffinity="1" group="1" mass="0"/>
    <geom name="obs_3" type="sphere" size="0.4"
              pos="0 -3 0" rgba="0.8 0.2 0.2 0.7"
              contype="1" conaffinity="1" group="1" mass="0"/>
    <geom name="obs_4" type="sphere" size="0.4"
              pos="2 2 1" rgba="0.8 0.2 0.2 0.7"
              contype="1" conaffinity="1" group="1" mass="0"/>

  </worldbody>

  <!-- ── Actuators ─────────────────────────────────────────────── -->
  <!--
    4 site-based motor actuators, one per thruster.
    class="thruster" inherits: ctrlrange=[-1,1], gear="20 0 0 0 0 0"
    gear format: [Fx Fy Fz Tx Ty Tz] in site local frame.
    "20 0 0 0 0 0" = 20N force along local +X only (pure thrust, no torque).

    ctrl[0] = thrust_top    (positive = forward)
    ctrl[1] = thrust_bot
    ctrl[2] = thrust_left
    ctrl[3] = thrust_right

    Example Python control mappings:
      Pure surge:  ctrl = [1, 1, 1, 1]        → 80N forward
      Pure heave+: ctrl = [1, -1, 0, 0]        → 20N up (net)
      Pure sway+:  ctrl = [0, 0, 1, -1]        → 20N left
      Yaw left:    ctrl = [-1, -1, 1, 1]        → rotate left
  -->
  <actuator>
    <motor name="thrust_top"   class="thruster" site="thruster_top"/>
    <motor name="thrust_bot"   class="thruster" site="thruster_bot"/>
    <motor name="thrust_left"  class="thruster" site="thruster_left"/>
    <motor name="thrust_right" class="thruster" site="thruster_right"/>
  </actuator>

  <!-- ── Sensors ───────────────────────────────────────────────── -->
  <!--
    All sensors read via: data.sensordata[start:end]
    Use model.sensor_adr and model.sensor_dim to find indices programmatically.

    Sensor index map (sensordata offsets):
      pos      : [0:3]   world XYZ
      quat     : [3:7]   world quaternion (w,x,y,z)
      linvel   : [7:10]  world linear velocity
      angvel   : [10:13] world angular velocity
      accel    : [13:16] body-frame linear acceleration (includes gravity if any)
      gyro     : [16:19] body-frame angular rate
      act_top  : [19]    actual thruster force top (N)
      act_bot  : [20]    actual thruster force bot
      act_left : [21]    actual thruster force left
      act_right: [22]    actual thruster force right
      rf_fwd   : [23]    rangefinder forward (m) — -1 if no hit
      rf_port  : [24]    rangefinder port
      rf_stbd  : [25]    rangefinder starboard
      rf_up    : [26]    rangefinder up
    Total sensordata length: 27
  -->
  <sensor>
    <!-- Navigation sensors (body frame via objtype=body) -->
    <framepos    name="pos"    objtype="body" objname="halcyon"/>
    <framequat   name="quat"   objtype="body" objname="halcyon"/>
    <framelinvel name="linvel" objtype="body" objname="halcyon"/>
    <frameangvel name="angvel" objtype="body" objname="halcyon"/>

    <!-- IMU sensors at dedicated site -->
    <accelerometer name="accel" site="imu"/>
    <gyro          name="gyro"  site="imu"/>

    <!--
      Actuator force sensors — read actual thrust produced each step.
      Useful for: energy penalty in reward, thrust allocation debugging,
      domain randomisation of actuator efficiency.
    -->
    <actuatorfrc name="act_top"   actuator="thrust_top"/>
    <actuatorfrc name="act_bot"   actuator="thrust_bot"/>
    <actuatorfrc name="act_left"  actuator="thrust_left"/>
    <actuatorfrc name="act_right" actuator="thrust_right"/>

    <!--
      Rangefinder sensors — return distance to nearest geom along site's -Z axis.
      cutoff="10.0" means returns -1 beyond 10m (water is open, 10m is generous).
      In Python env: use as proximity features or obstacle avoidance rewards.
      Note: rangefinders fire along site local -Z by MuJoCo convention.
      Sites are oriented so -Z points in the desired sensing direction.
    -->
    <rangefinder name="rf_fwd"  site="nose_tip"         cutoff="10.0"/>
    <rangefinder name="rf_port" site="range_port"        cutoff="5.0"/>
    <rangefinder name="rf_stbd" site="range_starboard"   cutoff="5.0"/>
    <rangefinder name="rf_up"   site="range_up"          cutoff="5.0"/>
  </sensor>

  <!-- ── Keyframes ─────────────────────────────────────────────── -->
  <!--
    "home" keyframe: AUV hovering at origin, zero velocity, level attitude.
    Use in Python env reset:
      mujoco.mj_resetDataKeyframe(model, data, 0)
    qpos for free joint: [x, y, z, qw, qx, qy, qz]
    qvel for free joint: [vx, vy, vz, wx, wy, wz]
    Goal body has no DOF so no entries needed beyond AUV.
  -->
  <keyframe>
    <key name="home"
         qpos="0 0 0  1 0 0 0"
         qvel="0 0 0  0 0 0"
         ctrl="0 0 0 0"/>
  </keyframe>

</mujoco>